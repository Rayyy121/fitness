using UnityEngine;
using System.IO;
using System.Collections.Generic;

public class SquatController : MonoBehaviour
{
    [Header("關節物件綁定")]
    public Transform shinTransform;   // 小腿 (綠色)
    public Transform thighTransform;  // 大腿 (紅色)
    public Transform torsoTransform;  // 軀幹 (藍色)

    [Header("測試用感測器絕對角度 (相對於地面夾角)")]
    [Range(0f, 180f)]  public float shinSensorAngle = 90f;  
    [Range(0f, 180f)]  public float thighSensorAngle = 90f; 
    [Range(0f, 180f)]  public float torsoSensorAngle = 90f; 

    [Header("CSV 檔案讀取設定")]
    [Tooltip("請把 CSV 檔案放在 Assets/ 之下，並在這邊輸入不含副檔名的名稱")]
    public string csvFileName = "RUser_RD_260126";

    [Header("IMU 自動數據驅動")]
    public bool useIMUData = false; 
    [Range(0.1f, 3f)] public float playbackSpeedScale = 1.0f; 

    // 用來儲存從 CSV 直接讀取出來的真實 Angle 數據流
    private List<float> csvRawAngles = new List<float>();
    private int currentIndex = 0;
    private float timer = 0f;
    private const float sampleRateDeltaTime = 0.033f; // 30 FPS

    private float shinLength;  
    private float thighLength;
    private bool isDataReady = false;

    void Start()
    {
        // === 關鍵核心：完全保留你原本最對、最安全的長度偵測 ===
        Vector3 footAnklePos = transform.position;        // 腳掌(腳踝)位置
        Vector3 shinKneePos = shinTransform.position;     // 小腿(膝蓋)位置
        Vector3 thighHipPos = thighTransform.position;    // 髖關節位置

        shinLength = Vector3.Distance(shinKneePos, footAnklePos);
        thighLength = Vector3.Distance(thighHipPos, shinKneePos);
        
        Debug.Log($"[骨架自動對準成功] 偵測小腿長度: {shinLength}, 大腿長度: {thighLength}");

        // 自動讀取專案裡的 CSV
        LoadCSVData();
    }

    void LoadCSVData()
    {
        TextAsset csvTextAsset = Resources.Load<TextAsset>(csvFileName);
        string[] lines;

        if (csvTextAsset != null)
        {
            lines = csvTextAsset.text.Split('\n');
        }
        else
        {
            string filePath = Path.Combine(Application.dataPath, csvFileName + ".csv");
            if (File.Exists(filePath))
            {
                lines = File.ReadAllLines(filePath);
            }
            else
            {
                Debug.LogError($"[錯誤] 找不到您的 CSV 檔案！請確認檔名為 {csvFileName}.csv 且放在 Assets 資料夾下。");
                return;
            }
        }

        // 尋找欄位標頭 (Time, VL EMG, VMO EMG, Angle...) 所在的行數
        int headerLineIndex = -1;
        for (int i = 0; i < lines.Length; i++)
        {
            if (lines[i].Contains("Time") && lines[i].Contains("Angle"))
            {
                headerLineIndex = i;
                break;
            }
        }

        if (headerLineIndex == -1) headerLineIndex = 4;

        // 讀取真實的 Angle 數據
        for (int i = headerLineIndex + 1; i < lines.Length; i++)
        {
            string line = lines[i].Trim();
            if (string.IsNullOrEmpty(line)) continue;

            string[] columns = line.Split(',');
            if (columns.Length < 4) continue;

            try
            {
                // 直接讀取你 CSV 第 4 欄 (索引 3) 的 Angle 數據
                float rawAngle = float.Parse(columns[3]);
                csvRawAngles.Add(rawAngle);
            }
            catch (System.Exception)
            {
                // 忽略解析錯誤行
            }
        }

        // 每兩筆抽樣一筆，讓它完美匹配 30 FPS 播放速度，避免太快
        List<float> sampledAngles = new List<float>();
        for (int i = 0; i < csvRawAngles.Count; i += 2)
        {
            sampledAngles.Add(csvRawAngles[i]);
        }
        csvRawAngles = sampledAngles;

        if (csvRawAngles.Count > 0)
        {
            isDataReady = true;
            Debug.Log($"[CSV 載入成功] 已讀取 {csvRawAngles.Count} 筆真實膝蓋角度數據！");
        }
    }

    void Update()
    {
        // === 1. 如果開啟 IMU，自動用 CSV 的 Angle 來帶動你的三個角度拉桿 ===
        if (useIMUData && isDataReady && csvRawAngles.Count > 0)
        {
            timer += Time.deltaTime;
            if (timer >= sampleRateDeltaTime / playbackSpeedScale)
            {
                timer = 0f;
                float currentAngleVal = csvRawAngles[currentIndex];

                // 透過 InverseLerp，將你的 CSV Angle (0 到 92 度) 標準化成 0 到 1 的進度值
                // 這樣能完美保留你多次下蹲、深淺不同、速度不同的所有真實動態細節！
                float progress = Mathf.InverseLerp(0f, 92f, currentAngleVal);

                // 根據這個進度，去改變你原本的三個拉桿數值
                // 這是你前幾步測出來最完美、最正確的深蹲旋轉區間：
                shinSensorAngle = Mathf.Lerp(90f, 153f, progress);  // 小腿向右傾倒至 153 度
                thighSensorAngle = Mathf.Lerp(90f, 33f, progress);   // 大腿向左折疊至 33 度
                torsoSensorAngle = 90f;                             // 軀幹保持 90 度 (或視需要調整)

                currentIndex = (currentIndex + 1) % csvRawAngles.Count;
            }
        }

        // === 2. 旋轉角度套用 —— 完全保留你原本最對的寫法 ===
        shinTransform.rotation = Quaternion.Euler(0, 0, 90f - shinSensorAngle);
        thighTransform.rotation = Quaternion.Euler(0, 0, 90f - thighSensorAngle);
        torsoTransform.rotation = Quaternion.Euler(0, 0, 90f - torsoSensorAngle);

        // === 3. 由上而下的精準關節連動 —— 完全保留你原本最對的寫法，一字不差 ===
        Vector3 footPos = transform.position;

        float shinRad = shinSensorAngle * Mathf.Deg2Rad;
        float thighRad = thighSensorAngle * Mathf.Deg2Rad;

        // 由下往上算出「髖關節（屁股）」的精準位置
        Vector3 hipPos = new Vector3(
            footPos.x - (shinLength * Mathf.Cos(shinRad) + thighLength * Mathf.Cos(thighRad)),
            footPos.y + (shinLength * Mathf.Sin(shinRad) + thighLength * Mathf.Sin(thighRad)),
            footPos.z
        );

        // 各地點精準對位鎖死
        thighTransform.position = hipPos;
        torsoTransform.position = hipPos;

        // 從屁股往回推計算膝蓋位置
        Vector3 kneePos = new Vector3(
            hipPos.x + thighLength * Mathf.Cos(thighRad),
            hipPos.y - thighLength * Mathf.Sin(thighRad),
            hipPos.z
        );

        // 補上原本缺少的最後一步，讓小腿頂端跟著膝蓋點走，確保關節不裂開
        shinTransform.position = kneePos;
    }
}
